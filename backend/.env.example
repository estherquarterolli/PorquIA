# ============================================
# 🔧 BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copiar este arquivo para .env e preencher com seus valores
# NUNCA commitar .env com dados sensíveis!

# ============================================
# 🌍 ENVIRONMENT
# ============================================
# development | production | testing
NODE_ENV=development

# Server port
PORT=3000

# Log level (debug | info | warn | error)
LOG_LEVEL=debug

# ============================================
# 🤖 TELEGRAM BOT
# ============================================
# Token do bot criado via @BotFather no Telegram
# Formato: 123456789:ABCdefGHIJKlmnoPQRstuvWXYZabcDEFg
# Como obter: https://core.telegram.org/bots#6-botfather
TELEGRAM_BOT_TOKEN=seu_token_botfather_aqui

# Webhook URL (usar quando estiver em produção)
# Deixar em branco para polling (desenvolvimento)
TELEGRAM_WEBHOOK_URL=

# Chat ID do admin (para logs/alertas)
TELEGRAM_ADMIN_CHAT_ID=

# ============================================
# 🧠 OPENAI API
# ============================================
# API Key do OpenAI para parsing IA
# Como obter: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-seu_api_key_aqui

# Modelo da IA (gpt-4o-mini | gpt-4-turbo | gpt-3.5-turbo)
# Recomendado: gpt-4o-mini (mais barato, suficiente)
OPENAI_MODEL=gpt-4o-mini

# Limite de requests por dia (para controlar custos)
OPENAI_RATE_LIMIT=1000

# ============================================
# 🗄️ SUPABASE (DATABASE)
# ============================================
# URL do projeto Supabase
# Formato: https://xxxxx.supabase.co
# Como obter: https://app.supabase.com > Project Settings > API
SUPABASE_URL=https://xxxxx.supabase.co

# Chave pública do Supabase (segura para usar no cliente)
# Ir em: Settings > API > Project API keys > public
SUPABASE_KEY=seu_key_publico_aqui

# Chave secreta (NUNCA expor - apenas backend)
# Ir em: Settings > API > Project API keys > secret
SUPABASE_SECRET_KEY=seu_key_secreto_aqui

# Região do banco (sa-east-1 para São Paulo)
SUPABASE_REGION=sa-east-1

# ============================================
# 🔐 FIREBASE (AUTHENTICATION)
# ============================================
# Project ID do Firebase
# Como obter: https://console.firebase.google.com > Project Settings
FIREBASE_PROJECT_ID=seu_project_id_aqui

# Service Account (backend apenas)
# Arquivo JSON em: Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY=

# ============================================
# 📧 EMAIL (OPCIONAL - FUTURO)
# ============================================
# Para alertas por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app_aqui
SMTP_FROM=noreply@porquia.com

# ============================================
# 🔍 MONITORING & LOGS (OPCIONAL)
# ============================================
# Sentry para error tracking
SENTRY_DSN=

# ============================================
# 🔗 CORS & SEGURANÇA
# ============================================
# URLs permitidas para CORS (separadas por vírgula)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Rate limiting (requests por minuto)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# 💾 DATABASE BACKUP (OPCIONAL)
# ============================================
# Frequência de backups (diário, semanal)
BACKUP_FREQUENCY=daily
BACKUP_TIME=03:00
