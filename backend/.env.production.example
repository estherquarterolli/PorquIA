# ============================================
# 🔧 BACKEND ENVIRONMENT VARIABLES - PRODUÇÃO
# ============================================
# Este arquivo é apenas um template
# Para produção, usar variáveis de ambiente do serviço de hospedagem
# (Railway, Heroku, AWS, DigitalOcean, etc)

# ============================================
# 🌍 ENVIRONMENT
# ============================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=error

# ============================================
# 🤖 TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=seu_token_botfather_aqui
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/webhook/telegram
TELEGRAM_ADMIN_CHAT_ID=

# ============================================
# 🧠 OPENAI API
# ============================================
OPENAI_API_KEY=sk-proj-seu_api_key_aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_RATE_LIMIT=1000

# ============================================
# 🗄️ SUPABASE (DATABASE)
# ============================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=seu_key_publico_aqui
SUPABASE_SECRET_KEY=seu_key_secreto_aqui
SUPABASE_REGION=sa-east-1

# ============================================
# 🔐 FIREBASE
# ============================================
FIREBASE_PROJECT_ID=seu_project_id_aqui
FIREBASE_SERVICE_ACCOUNT_KEY=

# ============================================
# 📧 EMAIL
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app_aqui
SMTP_FROM=noreply@porquia.com

# ============================================
# 🔍 MONITORING
# ============================================
SENTRY_DSN=https://seu_sentry_dsn_aqui

# ============================================
# 💳 ABACATE PAY (ASSINATURA)
# ============================================
ABACATE_PAY_API_KEY=abc_dev_seu_api_key_aqui
# Segredo configurado no painel do Abacate Pay e enviado como ?webhookSecret= na URL do webhook
ABACATE_PAY_WEBHOOK_SECRET=seu_webhook_secret_aqui
# URL do frontend (usada nos returnUrl/completionUrl do checkout)
FRONTEND_URL=https://porquia.com

# ============================================
# 🔗 SEGURANÇA
# ============================================
# URLs de produção
CORS_ORIGIN=https://porquia.com,https://www.porquia.com
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# 💾 BACKUP
# ============================================
BACKUP_FREQUENCY=daily
BACKUP_TIME=03:00
